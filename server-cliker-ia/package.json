{
  "name": "server-cliker-ia",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:cjs": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.cjs --format=cjs --packages=external --sourcemap",
    "start": "node dist/index.js",
    "start:cjs": "node dist/index.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:reset": "tsx scripts/reset-database.ts",
    "db:migrate": "tsx scripts/migrate-add-all-upgrades.ts",
    "db:init": "tsx scripts/reset-database.ts && tsx scripts/migrate-add-all-upgrades.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.24.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
